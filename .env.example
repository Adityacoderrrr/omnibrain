# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Qdrant ─────────────────────────────────────────────────────────────────
# Start with: docker-compose up -d
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key   # only needed for Qdrant Cloud

QDRANT_TEXT_COLLECTION=omnibrain_text
QDRANT_IMAGE_COLLECTION=omnibrain_images

# ─── LLM / VLM (Week 2+) ────────────────────────────────────────────────────
# If not set, the ingestion pipeline falls back to local deterministic embeddings
# OPENAI_API_KEY=sk-...

# ─── SQL Agent (Week 2+) ─────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/omnibrain_db

# ─── Observability / Langfuse (Week 4+) ─────────────────────────────────────
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Storage ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=storage/uploads
